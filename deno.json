{
  "name": "@webdetta/core",
  "version": "0.1.290",
  "license": "MIT",
  "exports": {
    "./common/dom": "./packages/common/dom.js",
    "./common/environment": "./packages/common/environment.js",
    "./common/utils": "./packages/common/utils.js",
    "./config/enable-polyfills": "./packages/config/enable-polyfills.js",
    "./config/handle-uncaught-errors": "./packages/config/handle-uncaught-errors.js",
    "./context/sync": "./packages/context/sync.js",
    "./context/async": "./packages/context/async.js",
    "./builder": "./packages/builder/index.js",
    "./convert": "./packages/convert/index.js",
    "./execution": "./packages/execution/index.js",
    "./i18n": "./packages/i18n/index.js",
    "./logger": "./packages/logger/index.js",
    "./reactivity": "./packages/reactivity/index.js",
    "./realcss": "./packages/realcss/index.js",
    "./realdom": "./packages/realdom/index.js",
    "./router": "./packages/router/index.js",
    "./rpc": "./packages/rpc/index.js",
    "./templater": "./packages/templater/index.js"
  },
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "deno.unstable",
      "dom",
      "dom.iterable"
    ]
  },
  "imports": {
    "zx/globals": "npm:zx/globals"
  },
  "exclude": [
    "dist"
  ],
  "publish": {
    "exclude": [
      "benchmarks",
      "examples",
      "tasks",
      "_",
      "dist",
      "packages/*/tests"
    ]
  },
  "tasks": {
    "test": "deno run -A tasks/test.js",
    "check": "deno run -A tasks/check.js",
    "check:types": "deno run -A tasks/check-types.js",
    "coverage": "deno run -A tasks/coverage.js",
    "bump": "deno run -A tasks/bump-version.js",
    "push": "deno run -A tasks/push.js",
    "generate-docs": "deno run -A tasks/generate-docs.js",
    "build:npm": "deno run -A tasks/build-npm.js"
  }
}
