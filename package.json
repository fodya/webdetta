      "default": "./packages/realdom/index.js"
    },
    "./router": {
      "types": "./packages/router/types/index.d.ts",
      "default": "./packages/router/index.js"
    },
    "./router/realdom-adapter": {
      "types": "./packages/router/types/realdom-adapter.d.ts",
      "default": "./packages/router/realdom-adapter.js"
    },
    "./rpc": {
      "types": "./packages/rpc/types/index.d.ts",
