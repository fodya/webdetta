    "./config/*": {
      "types": "./packages/config/types/*.d.ts",
      "default": "./packages/config/*.js"
    },
    "./context/sync": {
      "types": "./packages/context/types/sync.d.ts",
      "default": "./packages/context/sync.js"
    },
    "./context/async": {
      "types": "./packages/context/types/async.d.ts",
      "default": "./packages/context/async.js"
    },
    "./builder": {
      "types": "./packages/builder/types/index.d.ts",
      "default": "./packages/builder/index.js"
    },
    "./convert": {
      "types": "./packages/convert/types/index.d.ts",
      "default": "./packages/convert/index.js"
    },
    "./execution": {
      "types": "./packages/execution/types/index.d.ts",
      "default": "./packages/execution/index.js"
    },
    "./i18n": {
      "types": "./packages/i18n/types/index.d.ts",
      "default": "./packages/i18n/index.js"
    },
    "./logger": {
      "types": "./packages/logger/types/index.d.ts",
      "default": "./packages/logger/index.js"
    },
    "./reactivity": {
      "types": "./packages/reactivity/types/index.d.ts",
      "default": "./packages/reactivity/index.js"
